# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application URL (used for internal API calls and subdomain detection)
# Example: https://myapp.com  (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Calendrific API (for holiday sync)
# Get your free API key at https://calendarific.com/api-documentation
CALENDRIFIC_API_KEY=your_calendrific_api_key

# GitHub (Optional - for file uploads)
GITHUB_TOKEN=your_github_token
GITHUB_REPO=your_github_repo
GITHUB_OWNER=your_github_owner

# ─── Multi-Tenancy Setup ─────────────────────────────────────────────────────
# 1. Run supabase/migrations/01_MULTITENANCY_MIGRATION.sql in your Supabase project.
# 2. In Supabase Dashboard → Authentication → Hooks → Custom Access Token,
#    set the hook function to: public.custom_access_token_hook
# 3. Update the default school record to your real school name/subdomain:
#    UPDATE schools SET name='Your School Name', subdomain='yourschool'
#    WHERE id='00000000-0000-0000-0000-000000000001';
# 4. Create your super_admin user:
#    INSERT INTO user_role_links (user_id, role_id, school_id)
#    SELECT '<your-auth-user-id>', id, NULL FROM roles WHERE name = 'super_admin';
# 5. For production: add a wildcard DNS record *.yourdomain.com pointing to Vercel,
#    and add *.yourdomain.com as a custom domain in your Vercel project settings.
# ─────────────────────────────────────────────────────────────────────────────
